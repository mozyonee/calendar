{
  "name": "calendar",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/types",
    "apps/*"
  ],
  "scripts": {
    "dev:client": "npm run dev --workspace=apps/client",
    "dev:server": "npm run dev --workspace=apps/server",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,cjs,json,md}\" --ignore-path .gitignore",
    "tsc": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "prepare": "husky",
    "postinstall": "npm run build --workspace=packages/types"
  },
  "devDependencies": {
    "husky": "^8.0.3",
    "prettier": "^3.7.4"
  }
}
